{
  "name": "ats-scout",
  "version": "1.0.0",
  "description": "AI-powered ATS resume analyser. Any provider. BYOK. 100% local PDF parsing. Zero servers.",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "node scripts/copy-pdf-worker.js && node scripts/generate-icons.js",
    "prebuild": "node scripts/copy-pdf-worker.js",
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "zip": "cd dist && zip -r ../ats-scout.zip ."
  },
  "dependencies": {
    "jspdf": "^2.5.1",
    "pdfjs-dist": "^4.4.168"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^29.1.1",
    "vite": "^5.4.0",
    "vite-plugin-web-extension": "^4.1.1",
    "vitest": "^4.1.6"
  }
}
